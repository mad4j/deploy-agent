{
  "name": "my-app-deployment",
  "env": {
    "APP_NAME": "my-app",
    "BUILD_DIR": "./tmp/deploy-manager-example-build"
  },
  "actions": [
    {
      "name": "set-version",
      "type": "set_env",
      "key": "VERSION",
      "value": "1.0.0"
    },
    {
      "name": "create-build-dir",
      "type": "mkdir",
      "path": "${BUILD_DIR}",
      "recursive": true
    },
    {
      "name": "write-version-file",
      "type": "write_file",
      "path": "${BUILD_DIR}/version.txt",
      "content": "${APP_NAME}-${VERSION}\n"
    },
    {
      "name": "backup-version-file",
      "type": "copy_file",
      "source": "${BUILD_DIR}/version.txt",
      "destination": "${BUILD_DIR}/version.bak",
      "overwrite": true
    },
    {
      "name": "rename-backup",
      "type": "move_file",
      "source": "${BUILD_DIR}/version.bak",
      "destination": "${BUILD_DIR}/version.previous.txt",
      "overwrite": true
    },
    {
      "name": "wait-for-version",
      "type": "wait",
      "until_file_exists": "${BUILD_DIR}/version.txt",
      "timeout_ms": 5000,
      "interval_ms": 200
    },
    {
      "name": "cleanup-version-backup",
      "type": "remove_path",
      "path": "${BUILD_DIR}/version.previous.txt",
      "ignore_missing": true
    },
    {
      "name": "cleanup-build-dir",
      "type": "remove_path",
      "path": "${BUILD_DIR}",
      "recursive": true
    }
  ]
}
